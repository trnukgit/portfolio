# Notion 連携トークン (https://www.notion.so/my-integrations で作成)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Works データベースの ID (URLの`?v=...`より前の32文字)
NOTION_WORKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Profile データベースの ID (任意。1 行だけのデータベースで About セクションの
# 写真・名前・所属・自己紹介を管理する。未設定なら About は非表示)
NOTION_PROFILE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Viewers データベースの ID (任意。ギャラリーの「鑑賞者」画像を Notion で管理したい場合のみ。
# 未設定なら public/images/viewers/ 内のファイルが使われる)
NOTION_VIEWERS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hero データベースの ID (任意。ヒーロー文の背景イラストを Notion で管理する場合のみ。
# 未設定ならヒーローには背景イラスト無し。1 行目の Image / Image (Mobile) を読む)
NOTION_HERO_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
