---
import type { Work } from '../lib/types';
import type { Placement } from '../lib/wall-layout';
import { strings, type Lang } from '../config';
import { url, workUrl } from '../lib/url';

interface Props {
  work: Work;
  index: number;
  lang: Lang;
  placement: Placement;
}

const { work, index, lang, placement } = Astro.props;
const t = strings(lang);
const href = workUrl(lang, work.slug);

const num = String(index + 1).padStart(2, '0');
const year = work.date ? new Date(work.date).getFullYear() : null;

const styleStr = [
  `--x:${placement.x}%`,
  `--y:${placement.y}%`,
  `--w:${placement.w}%`,
  `--aspect:${placement.aspect}`,
].join(';');

const frameClass = `frame frame--${placement.frame}`;
---

<a class="work-card" href={href} data-reveal style={styleStr}>
  <div class={frameClass}>
    <div class="art-wrap">
      {work.cover ? (
        <img class="art" src={url(work.cover)} alt={work.title} loading="lazy" />
      ) : (
        <div class="art art-fallback" aria-hidden="true">
          <span class="ph-num">{num}</span>
        </div>
      )}

      <div class="reveal" aria-hidden="true">
        <h3 class="r-title">{work.title}</h3>
        {work.summary && <p class="r-summary">{work.summary}</p>}
        <p class="r-cta">{t.card.cta} <span class="r-arrow">→</span></p>
      </div>
    </div>
  </div>

  <div class="caption">
    <p class="catchphrase">{work.catchphrase || work.title}</p>
    <p class="meta">
      {work.tags?.length > 0 && <span class="tags">{work.tags.join(' · ')}</span>}
      {work.tags?.length > 0 && year && <span class="dot"> · </span>}
      {year && <span class="year">{year}</span>}
    </p>
  </div>
</a>

<style>
  .work-card {
    position: absolute;
    left: var(--x, 0%);
    top: var(--y, 0%);
    width: var(--w, 20%);
    color: var(--ink);
    display: block;
  }

  .frame {
    aspect-ratio: var(--aspect, 1);
    width: 100%;
    container-type: inline-size;
  }

  .art-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .art {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.9s var(--ease), filter 0.6s var(--ease);
  }

  .art-fallback {
    background: var(--bg-deep);
    display: grid;
    place-items: center;
  }

  .ph-num {
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 5cqw, 3rem);
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }

  /* ---- Hover scrim (the "before-gallery" reveal pattern) ---- */
  .reveal {
    position: absolute;
    inset: 0;
    padding: clamp(1rem, 2.5cqw, 1.6rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    color: var(--scrim-text);
    background: var(--scrim);
    opacity: 0;
    transition: opacity 0.45s var(--ease);
  }

  .r-title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1rem, 2.2cqw, 1.4rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    transform: translateY(8px);
    transition: transform 0.45s var(--ease) 0.05s;
  }

  .r-summary {
    margin: 0;
    font-size: clamp(0.78rem, 1.4cqw, 0.92rem);
    line-height: 1.5;
    color: rgba(244, 241, 232, 0.85);
    max-width: 32ch;
    transform: translateY(8px);
    transition: transform 0.45s var(--ease) 0.1s;
  }

  .r-cta {
    margin: 0.4rem 0 0;
    font-family: var(--font-mono);
    font-size: clamp(0.62rem, 1.1cqw, 0.74rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    transform: translateY(8px);
    transition: transform 0.45s var(--ease) 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .r-arrow {
    transition: transform 0.4s var(--ease);
  }

  /* ---- Caption (always visible) ---- */
  .caption {
    margin-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .catchphrase {
    margin: 0;
    font-size: clamp(0.86rem, 1.3cqw, 0.98rem);
    line-height: 1.45;
    color: var(--ink);
    font-weight: 400;
  }

  .meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .meta .dot { color: var(--ink-muted); opacity: 0.5; }

  /* ---- Hover (PC) ---- */
  @media (hover: hover) and (pointer: fine) {
    .work-card:hover .reveal,
    .work-card:focus-visible .reveal {
      opacity: 1;
    }
    .work-card:hover .art,
    .work-card:focus-visible .art {
      transform: scale(1.04);
    }
    .work-card:hover .r-title,
    .work-card:hover .r-summary,
    .work-card:hover .r-cta,
    .work-card:focus-visible .r-title,
    .work-card:focus-visible .r-summary,
    .work-card:focus-visible .r-cta {
      transform: translateY(0);
    }
    .work-card:hover .r-arrow,
    .work-card:focus-visible .r-arrow {
      transform: translateX(4px);
    }
  }

  /* ---- Mobile / touch: center-line reveal ---- */
  @media (hover: none) {
    .work-card.is-active .reveal {
      opacity: 1;
    }
    .work-card.is-active .art {
      transform: scale(1.03);
    }
    .work-card.is-active .r-title,
    .work-card.is-active .r-summary,
    .work-card.is-active .r-cta {
      transform: translateY(0);
    }
  }

  /* ---- Mobile layout: vertical stack with cluster feel ---- */
  @media (max-width: 760px) {
    .work-card {
      position: relative;
      left: auto !important;
      top: auto !important;
      margin: 0 auto 2.5rem;
    }
    .work-card { width: 78% !important; }
    .work-card:nth-child(3n+1) {
      width: 84% !important;
      margin-left: 4%;
      margin-right: auto;
    }
    .work-card:nth-child(3n+2) {
      width: 70% !important;
      margin-left: auto;
      margin-right: 6%;
    }
    .work-card:nth-child(3n+3) {
      width: 76% !important;
      margin-inline: auto;
    }
  }
</style>
